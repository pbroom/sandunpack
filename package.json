{
	"name": "sandunpack",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@10.16.1",
	"workspaces": [
		"fixtures/*"
	],
	"scripts": {
		"install:vendor": "bash ./scripts/vendor-yarn.sh install",
		"build:vendor": "bash ./scripts/build-vendor.sh",
		"check:fixture-links": "node ./scripts/check-fixture-links.mjs",
		"build:fixtures": "pnpm -r --filter './fixtures/*' build",
		"check:fixtures": "pnpm -r --filter './fixtures/*' check",
		"start:all": "bash ./scripts/start-all.sh",
		"open:all": "bash ./scripts/open-all.sh all",
		"stop:all": "bash ./scripts/stop-all.sh",
		"status:all": "bash ./scripts/status-all.sh",
		"dev:minimal-race-react": "pnpm --filter minimal-startup-race-react dev",
		"dev:minimal-race-client": "pnpm --filter minimal-startup-race-client dev",
		"dev:timeout-restart": "pnpm --filter timeout-restart-repro dev",
		"dev:heavy-repro": "pnpm --filter color-kit-plane-api-repro dev",
		"dev:heavy-timeout-disconnect": "pnpm --filter heavy-timeout-disconnect-repro dev"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"devDependencies": {
		"@types/node": "^25.5.0"
	}
}
